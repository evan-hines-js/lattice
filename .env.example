# Registry credentials for e2e tests and pull-through caches
# Copy to .env and fill in your values
GHCR_USER=your-github-username
GHCR_TOKEN=ghp_your_token_here
DOCKERHUB_USER=your-dockerhub-username
DOCKERHUB_TOKEN=dckr_pat_your_token_here

# Dev service endpoints (docker-compose)
# These MUST be set to an IP reachable from both the test runner AND cluster pods.
# There are no defaults — tests will panic if these are missing.
LATTICE_KEYCLOAK_URL=http://10.0.0.131:8080
LATTICE_VAULT_URL=http://10.0.0.131:8200
LATTICE_PIHOLE_URL=http://10.0.0.131:8053
LATTICE_PIHOLE_RESOLVER=10.0.0.131:5353
